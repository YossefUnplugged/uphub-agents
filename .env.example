# uphub loop-control credentials (ADR-008) — copy to your machine's USER env vars or a local .env
# you source before running the tick. NEVER commit real values; .env is gitignored.
#
# Create the token: https://id.atlassian.com/manage-profile/security/api-tokens → "Create API token".
# It is user-scoped (acts as you), local-only, and revocable in one click.
# Used ONLY by wrapper scripts (scripts/lib/jira.mjs): the poll JQL, the /myself health gate, and the
# mechanical ai-blocked label+comment. The agent never sees it.

JIRA_BASE_URL=https://unplugged.atlassian.net
JIRA_EMAIL=yossef@unplugged.com
JIRA_API_TOKEN=paste-your-token-here
